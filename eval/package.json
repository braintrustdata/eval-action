{
  "name": "typescript-action",
  "description": "GitHub Actions TypeScript template",
  "version": "0.0.0",
  "author": "",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/actions/typescript-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "bugs": {
    "url": "https://github.com/actions/typescript-action/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vp run package",
    "format:write": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint .",
    "watch": "vp run package:watch",
    "package": "vp pack",
    "package:watch": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "all": "vp check && vp run test && vp run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "braintrust": "^3.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.4.5"
  }
}
